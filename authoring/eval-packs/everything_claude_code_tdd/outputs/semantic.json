            "file": "skills/tdd-workflow/SKILL.md",
            "must_contain": "## TDD Workflow Steps"
          }
        ]
      },
      {
        "key": "implementation_code",
        "writable": true,
        "why": "The workflow explicitly requires implementing code after the RED gate.",
        "evidence": [
          {
            "file": "skills/tdd-workflow/SKILL.md",
            "must_contain": "### Step 4: Implement Code"
          }
        ]
      },
      {
        "key": "tests_checks",
        "writable": true,
        "why": "The workflow requires generating test cases, running tests, and meeting coverage thresholds.",
        "evidence": [
          {
            "file": "skills/tdd-workflow/SKILL.md",
            "must_contain": "### Step 2: Generate Test Cases"
          },
          {
            "file": "skills/tdd-workflow/SKILL.md",
            "must_contain": "### Step 7: Verify Coverage"
          }
        ]
      },
      {
        "key": "evidence_records",
        "writable": true,
        "why": "The workflow requires Git checkpoint commits after RED, GREEN, and refactor stages.",
        "evidence": [
          {
            "file": "skills/tdd-workflow/SKILL.md",
            "must_contain": "### 4. Git Checkpoints"
          },
          {
            "file": "skills/tdd-workflow/SKILL.md",
            "must_contain": "create a checkpoint commit after each TDD stage"
          }
        ]
      },
      {
        "key": "specs_plans",
        "writable": false,
        "why": "The workflow starts from user journeys and test cases, but it does not define a persistent spec or plan artifact.",
        "evidence": [
          {
            "file": "skills/tdd-workflow/SKILL.md",
            "must_contain": "### Step 1: Write User Journeys"
          }
        ]
      },
      {
        "key": "qa_release_review",
        "writable": false,
        "why": "Coverage checks are part of the TDD loop, but the workflow does not define a separate QA or release review artifact.",
        "evidence": [
          {
            "file": "skills/tdd-workflow/SKILL.md",
            "must_contain": "### Step 7: Verify Coverage"
          }
        ]
      }
    ]
  },
  "recovery": {
    "label": "fragile",
    "non_success_states": [
      "invalid_red"
    ],
    "has_blocked_reason": false,
    "has_next_step": false,
    "has_files_touched": false,
    "has_final_validation": true,
    "evidence": [
      {
        "file": "skills/tdd-workflow/SKILL.md",
        "must_contain": "A test that was only written but not compiled and executed does not count as RED."
      },
      {
        "file": "skills/tdd-workflow/SKILL.md",
        "must_contain": "Do not edit production code until this RED state is confirmed."
      }
    ]
  }
