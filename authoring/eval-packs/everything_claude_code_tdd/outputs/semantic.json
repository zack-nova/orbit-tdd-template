  "use_case_evidence": [
    {
      "file": "skills/tdd-workflow/SKILL.md",
      "must_contain": "description: Use this skill when writing new features, fixing bugs, or refactoring code."
    },
    {
      "file": "skills/tdd-workflow/SKILL.md",
      "must_contain": "Enforces test-driven development with 80%+ coverage"
    }
  ],
  "startup": {
    "phases": [
      {
        "files": [
          "README.md"
        ],
        "why": "The README tells the user that skills are the primary workflow surface.",
        "evidence": [
          {
            "file": "README.md",
            "must_contain": "Skills are the primary workflow surface."
          }
        ]
      },
      {
        "files": [
          "skills/tdd-workflow/SKILL.md"
        ],
        "why": "The skill file defines the actual TDD workflow, coverage policy, and required test types.",
        "evidence": [
          {
            "file": "skills/tdd-workflow/SKILL.md",
            "must_contain": "# Test-Driven Development Workflow"
          },
          {
            "file": "skills/tdd-workflow/SKILL.md",
            "must_contain": "## TDD Workflow Steps"
          }
        ]
      }
    ]
  },
  "verification": {
    "label": "strong",
    "actions": [
      {
        "id": "red_gate",
        "kind": "target_check",
        "why": "Production changes are blocked until a valid RED state is confirmed.",
        "evidence": [
          {
            "file": "skills/tdd-workflow/SKILL.md",
            "must_contain": "### Step 3: Run Tests (They Should Fail)"
          },
          {
            "file": "skills/tdd-workflow/SKILL.md",
            "must_contain": "This step is mandatory and is the RED gate for all production changes."
          }
        ]
      },
      {
        "id": "green_rerun",
        "kind": "rerun_same_target",
        "why": "The same relevant test target must be rerun and confirmed GREEN after the fix.",
        "evidence": [
          {
            "file": "skills/tdd-workflow/SKILL.md",
            "must_contain": "### Step 5: Run Tests Again"
          },
          {
            "file": "skills/tdd-workflow/SKILL.md",
            "must_contain": "Rerun the same relevant test target after the fix"
          }
        ]
      },
      {
        "id": "coverage_validation",
        "kind": "final_validation",
        "why": "The workflow ends with an explicit coverage verification step.",
        "evidence": [
          {
            "file": "skills/tdd-workflow/SKILL.md",
            "must_contain": "### Step 7: Verify Coverage"
          },
          {
            "file": "skills/tdd-workflow/SKILL.md",
            "must_contain": "npm run test:coverage"
          }
        ]
      }
    ],
    "has_probe": false
  },
  "write_boundary": {
    "surfaces": [
      {
        "key": "entry_brief",
        "writable": false,
